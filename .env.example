# Dedicated SEO Supabase project (SEO data + downstream SEO sessions).
#
# Frontend code may ONLY ever use the public URL + anon key below.
# NEVER put a Supabase service role key in a VITE_ env var (or anywhere
# in frontend code) — VITE_ variables are bundled into the client build
# and are publicly readable in the browser.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Canonical Digibility app and its `seo-bridge` Edge Function.
# Supplying all three enables cross-project SSO. Leaving them blank preserves
# the existing standalone TEST/local password-login fallback.
#
# Localhost verification example (Digibility :8080, SEO :8090):
#   VITE_DIGIBILITY_APP_URL=http://localhost:8080
#   VITE_DIGIBILITY_BRIDGE_URL=http://127.0.0.1:54321/functions/v1/seo-bridge
#   VITE_DIGIBILITY_ANON_KEY=<Digibility Core anon/publishable key>
# Production example:
#   VITE_DIGIBILITY_APP_URL=https://app.digibility.com
#   VITE_DIGIBILITY_BRIDGE_URL=https://<core-ref>.supabase.co/functions/v1/seo-bridge
VITE_DIGIBILITY_APP_URL=http://localhost:8080
VITE_DIGIBILITY_BRIDGE_URL=
VITE_DIGIBILITY_ANON_KEY=

# Optional: only needed if you override the default SEO origin used by Digibility
# linked logout (Digibility DEV defaults to http://localhost:8090).
# VITE_SEO_APP_URL=http://localhost:8090

# Controls whether SEO services read/write mock data or a real (test) Supabase
# project. Accepted values: "mock" | "supabase".
#
# - "mock" (default): all SEO services use local mock adapters. No Supabase
#   connection is required or attempted. This is what the app uses if this
#   variable is left blank or unset.
# - "supabase": opt-in for wiring individual services against a Supabase
#   TEST/STAGING project only, once Supabase URL + anon key above are set.
#   If they are missing/invalid, the app safely falls back to mock mode and
#   logs a console warning — it will never crash on a bad/missing config.
#
# Do NOT point this at a production Supabase project until backend
# production apply has been explicitly reviewed and approved
# (see BACKEND_MILESTONE_HANDOFF.md, section 5).
VITE_SEO_DATA_MODE=mock
